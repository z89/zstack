#!/usr/bin/env bash
set -euo pipefail

# Capture baseline lint/test state for a project.
# Used by hooks to distinguish pre-existing failures from new ones.

if [ ! -f .zstack/project.json ]; then
  echo '{"error": "No .zstack/project.json found. Run zstack-setup first."}'
  exit 1
fi

LINT_CMD=$(jq -r '.lint_cmd // empty' .zstack/project.json)
TYPECHECK_CMD=$(jq -r '.typecheck_cmd // empty' .zstack/project.json)
TEST_CMD=$(jq -r '.test_cmd // empty' .zstack/project.json)

LINT_ERRORS=0
TYPECHECK_ERRORS=0
TEST_FAILURES=0

# Count lint errors
if [ -n "$LINT_CMD" ]; then
  LINT_ERRORS=$($LINT_CMD 2>&1 | grep -c "error\|Error" || echo 0)
fi

# Count typecheck errors
if [ -n "$TYPECHECK_CMD" ]; then
  TYPECHECK_ERRORS=$($TYPECHECK_CMD 2>&1 | grep -c "error\|Error" || echo 0)
fi

# Count test failures
if [ -n "$TEST_CMD" ]; then
  TEST_FAILURES=$($TEST_CMD 2>&1 | grep -cE "fail|FAIL|FAILED" || echo 0)
fi

cat > .zstack/baseline.json << BASE
{
  "lint_errors": $LINT_ERRORS,
  "typecheck_errors": $TYPECHECK_ERRORS,
  "test_failures": $TEST_FAILURES,
  "captured_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "branch": "$(git branch --show-current 2>/dev/null || echo unknown)"
}
BASE

echo "Baseline captured: $LINT_ERRORS lint errors, $TYPECHECK_ERRORS type errors, $TEST_FAILURES test failures"
